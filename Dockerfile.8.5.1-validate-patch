# ============================================================================
# 补丁镜像 (Thin Patch — 只装缺失依赖)
# ============================================================================
# 基于已有的 8.5.1-validate 镜像，仅添加缺失的 Python 包：
#   - transformers >= 4.46
#   - regex (支持 \p{L} / \p{N} Unicode 属性)
#   - tiktoken (BPE 分词器)
#
# 新层大小：~150 MB 压缩 / ~600 MB 解压
# ============================================================================

ARG BASE_IMAGE=ghcr.io/lim12137/funasr-cann:8.5.1-validate
FROM ${BASE_IMAGE}

# 只装 3 个缺失包，不重装 torch / funasr / modelscope 等已有包
RUN python3 -m pip install --no-cache-dir \
        "transformers>=4.46" \
        "regex" \
        "tiktoken"

# 紧急运行时 shim（真实包已装，仅作备用）
COPY verify/shim/ /opt/verify/shim/

# 验证新包可导入
RUN python3 -c "from importlib.metadata import version; \
    packages = ('transformers', 'tiktoken', 'regex'); \
    [print(f'{package}={version(package)}') for package in packages]"
